{
  "name": "mcp-openstamanager",
  "version": "1.0.0",
  "description": "MCP Server for OpenSTAManager - Anagrafiche management",
  "main": "dist/index.js",
  "scripts": {
    "build": "node_modules/.bin/esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:axios --external:zod --external:zod-to-json-schema --external:dotenv",
    "start": "node dist/index.js",
    "dev": "node_modules/.bin/tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
